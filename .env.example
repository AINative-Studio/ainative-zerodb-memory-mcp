# ZeroDB Agent Memory MCP Configuration

# ===========================================
# Connection Settings
# ===========================================

# API endpoint (auto-detects if not set)
# For ZeroLocal: http://localhost:8000
# For Cloud: https://api.ainative.studio
# ZERODB_API_URL=http://localhost:8000

# Authentication (required)
ZERODB_USERNAME=your-email@example.com
ZERODB_PASSWORD=your-password
ZERODB_PROJECT_ID=your-project-id

# ===========================================
# Context Window Management
# ===========================================

# Maximum tokens in context window (default: 8192)
# Supports up to 128000 for large context models
CONTEXT_WINDOW=8192

# Memory pruning strategy (default: hybrid)
# Options: relevance, recency, hybrid
PRUNE_STRATEGY=hybrid

# Always keep N most recent messages (default: 5)
KEEP_RECENT=5

# Keep memories tagged as "important" (default: true)
KEEP_IMPORTANT=true

# ===========================================
# Automatic Summarization
# ===========================================

# Enable automatic summarization (default: true)
SUMMARIZE_ENABLED=true

# Summarize after N messages (default: 20)
SUMMARIZE_AFTER=20

# Model for summarization (default: claude-3-haiku-20240307)
SUMMARY_MODEL=claude-3-haiku-20240307

# Keep original messages after summarizing (default: false)
KEEP_ORIGINALS=false

# ===========================================
# Memory Decay
# ===========================================

# Enable memory decay over time (default: false)
DECAY_ENABLED=false

# Half-life in days (default: 30)
# After this many days, importance score is halved
DECAY_HALFLIFE=30

# Tags to preserve from decay (comma-separated)
PRESERVE_TAGS=important,permanent

# ===========================================
# Embedding Configuration
# ===========================================

# Auto-embed memories (default: true)
AUTO_EMBED=true

# Embedding model (default: BAAI/bge-small-en-v1.5)
# Options: BAAI/bge-small-en-v1.5 (384d), BAAI/bge-base-en-v1.5 (768d), BAAI/bge-large-en-v1.5 (1024d)
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
